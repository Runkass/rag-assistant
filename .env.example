# --- PostgreSQL + pgvector ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rag
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag

# --- Models ---
# Multilingual embeddings (RU + EN), 384-dim, fast on CPU.
# E5-family models require "passage:" / "query:" prefixes — handled in src/embeddings.py.
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# Cross-encoder reranker.
RERANKER_MODEL=BAAI/bge-reranker-base

# Where Hugging Face caches downloaded weights.
HF_HOME=./.hf_cache

# --- Retrieval ---
# Vector search returns this many candidates, the reranker keeps TOP_K_FINAL.
TOP_K_RETRIEVE=20
TOP_K_FINAL=5

# --- LLM (OpenAI-compatible: OpenAI, OpenRouter, vLLM, GigaChat-compatible gateway) ---
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=sk-replace-me
LLM_MODEL=qwen/qwen-2.5-7b-instruct:free

# --- Chunking ---
CHUNK_SIZE=600
CHUNK_OVERLAP=80
